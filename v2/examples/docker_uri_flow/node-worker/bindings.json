{
  "version": "urirun.bindings.v2",
  "bindings": {
    "node://node-worker/text/slugify": {
      "kind": "command",
      "adapter": "local-service",
      "inputSchema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string" }
        },
        "additionalProperties": false
      },
      "meta": { "label": "Slugify text", "language": "nodejs" }
    }
  }
}
