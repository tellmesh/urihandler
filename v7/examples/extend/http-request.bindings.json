{
  "bindings": {
    "api://github/repo/get": {
      "kind": "http",
      "adapter": "fetch",
      "method": "GET",
      "url": "https://api.github.com/repos/{owner}/{repo}",
      "params": {
        "owner": { "required": true },
        "repo": { "required": true }
      }
    },
    "api://github/issue/create": {
      "kind": "http",
      "adapter": "fetch",
      "method": "POST",
      "url": "https://api.github.com/repos/{owner}/{repo}/issues",
      "params": {
        "owner": { "required": true },
        "repo": { "required": true }
      }
    }
  }
}
