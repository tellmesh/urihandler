{
  "bindings": {
    "ops://local/notify/send": {
      "kind": "cli",
      "adapter": "spawn",
      "command": ["bash", "{script}", "{channel}"],
      "env": { "MESSAGE": "{message}" },
      "params": {
        "script": { "default": "notify.sh" },
        "channel": { "default": "general" },
        "message": { "required": true }
      }
    },
    "ops://local/notify/restart": {
      "kind": "shell",
      "adapter": "shell-template",
      "template": "systemctl restart {service}",
      "params": { "service": { "required": true } }
    }
  }
}
