{
  "bindings": {
    "cli://local/git/status": "git status",

    "media://local/video/transcode": {
      "kind": "cli",
      "adapter": "spawn",
      "command": ["ffmpeg", "-i", "{input}", "-vf", "scale={width}:{height}", "{output}"],
      "params": {
        "input": { "required": true },
        "output": { "required": true },
        "width": { "default": 1280 },
        "height": { "default": 720 }
      },
      "meta": { "label": "Transcode video (ffmpeg)" }
    },

    "img://ffmpeg/video/thumbnail": {
      "kind": "docker",
      "adapter": "docker-run",
      "image": "jrottenberg/ffmpeg",
      "mount": ".",
      "command": ["-i", "{input}", "-ss", "{at}", "-vframes", "1", "{output}"],
      "params": {
        "input": { "required": true },
        "output": { "default": "thumb.png" },
        "at": { "default": "00:00:01" }
      },
      "meta": { "label": "Thumbnail (docker ffmpeg)" }
    },

    "container://api/db/backup": {
      "kind": "docker",
      "adapter": "docker-exec",
      "command": ["pg_dump", "-U", "{user}", "{database}"],
      "params": { "user": { "default": "postgres" }, "database": { "required": true } },
      "meta": { "label": "DB backup (docker exec)" }
    },

    "api://github/repo/get": {
      "kind": "http",
      "adapter": "fetch",
      "method": "GET",
      "url": "https://api.github.com/repos/{owner}/{repo}",
      "params": { "owner": { "default": "tellmesh" }, "repo": { "default": "urihandler" } },
      "meta": { "label": "GitHub repo (real GET)" }
    },

    "ops://local/notify/send": {
      "kind": "cli",
      "adapter": "spawn",
      "command": ["bash", "notify.sh", "{channel}"],
      "env": { "MESSAGE": "{message}" },
      "params": { "channel": { "default": "general" }, "message": { "required": true } },
      "meta": { "label": "Notify (cli + env)" }
    },

    "shell://local/system/restart": {
      "kind": "shell",
      "adapter": "shell-template",
      "template": "systemctl restart {service}",
      "params": { "service": { "required": true } },
      "meta": { "label": "Restart service (shell)" }
    }
  }
}
