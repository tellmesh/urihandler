{
  "version": "urihandler.policy.v6",
  "defaultMode": "dry-run",
  "execute": {
    "allow": [
      "cli://**",
      "media://**",
      "img://**",
      "container://**",
      "api://**",
      "ops://**"
    ],
    "deny": [
      "shell://**"
    ]
  },
  "allowShellTemplates": false,
  "maxArgs": 16
}
